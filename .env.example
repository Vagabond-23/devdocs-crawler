# ============================================
# DevDocs Crawler — Environment Configuration
# ============================================
# Copy to .env and adjust values as needed.

# --- PostgreSQL ---
POSTGRES_USER=devdocs
POSTGRES_PASSWORD=devdocs_secret
POSTGRES_DB=devdocs
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://devdocs:devdocs_secret@postgres:5432/devdocs

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Meilisearch ---
MEILI_URL=http://meilisearch:7700
MEILI_MASTER_KEY=devdocs_meili_master_key

# --- Crawler Settings ---
CRAWLER_MAX_WORKERS=8
CRAWLER_MAX_DEPTH=3
CRAWLER_MAX_PAGES_PER_HOST=5000
CRAWLER_DEFAULT_DELAY_MS=1000
CRAWLER_REQUEST_TIMEOUT=30
CRAWLER_MAX_RETRIES=3
CRAWLER_USER_AGENT=DevDocsCrawler/1.0 (+https://github.com/yourusername/devdocs-crawler)

# --- Allowed Hosts (comma-separated) ---
CRAWLER_ALLOWED_HOSTS=docs.python.org,developer.mozilla.org,fastapi.tiangolo.com,kubernetes.io

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
